# Instagram Graph API
IG_USER_ID=INSTAGRAM_USER_ID_BURAYA
IG_ACCESS_TOKEN=INSTAGRAM_ACCESS_TOKEN_BURAYA

# Haber Çekim Zamanlaması (Cron)
# Her saat başı çalışır (cron: 0 * * * *)
CRON_SCHEDULE=0 * * * *

# Railway production
PUBLIC_URL=https://PROJE_ADI.up.railway.app
DATA_DIR=/data
RUN_PIPELINE_ON_START=false

# Imgur API (Opsiyonel, görsel fallback için)
IMGUR_CLIENT_ID=IMGUR_CLIENT_ID_BURAYA

# Telegram — Bildirim ve Onay Sistemi
TELEGRAM_BOT_TOKEN=TELEGRAM_BOT_TOKEN_BURAYA
TELEGRAM_CHAT_ID=TELEGRAM_CHAT_ID_BURAYA

# Mersin Manşet Web Portalı API Adresi
MERSIN_MANSET_API_URL=https://mersinmanset.tr


# WordPress REST API Entegrasyonu
WORDPRESS_ENABLED=true
WORDPRESS_SITE_URL=https://www.mersinmanset.tr
WORDPRESS_USERNAME=WORDPRESS_KULLANICI_ADI
WORDPRESS_APP_PASSWORD=WORDPRESS_UYGULAMA_SIFRESI

