# MERSINMANSETBOT Configuration Example
# Copy this to .env and fill in the credentials

# Telegram — Approval and Notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Imgur (Optional fallback)
IMGUR_CLIENT_ID=

# Zernio (TikTok integration)
ZERNIO_API_KEY=

# Instagram API (Meta Graph API)
IG_USER_ID=
IG_ACCESS_TOKEN=

# WordPress REST API
WORDPRESS_ENABLED=true
WORDPRESS_SITE_URL=https://mersinmanset.tr
WORDPRESS_USERNAME=admin
WORDPRESS_APP_PASSWORD=

# Portal API URL (Mersin Manşet)
MERSIN_MANSET_API_URL=https://mersinmanset.tr

# Scheduler Schedule (hourly)
CRON_SCHEDULE=0 * * * *
# Server Port (Express)
PORT=3000
